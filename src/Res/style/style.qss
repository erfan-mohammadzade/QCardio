/* ============================================================
   ECG MEDICAL APP STYLESHEET
   Dark clinical theme with high contrast for patient monitoring
   Designed for QML / Qt Widgets applications
   ============================================================ */

/* ---------- GLOBAL ---------- */
* {
    font-family: "Segoe UI", "Roboto", "Helvetica Neue", sans-serif;
}

QMainWindow, QDialog, QWidget {
    background-color: #1a1e24;
    color: #e0e4e8;
}

/* ---------- APPLICATION WINDOW ---------- */
QApplication {
    background-color: #1a1e24;
}

/* ---------- MAIN WINDOW ---------- */
#mainWindow {
    background-color: #1a1e24;
}

/* ---------- MENU BAR ---------- */
QMenuBar {
    background-color: #252b33;
    color: #c8d0d8;
    border-bottom: 1px solid #3a414a;
    padding: 4px 8px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #3a4a5a;
    color: #ffffff;
}

QMenu {
    background-color: #2c333c;
    border: 1px solid #3a414a;
    border-radius: 6px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 24px 6px 16px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #3a6ea5;
    color: #ffffff;
}

/* ---------- TOOLBARS ---------- */
QToolBar {
    background-color: #20262e;
    border: none;
    border-bottom: 1px solid #2e3640;
    padding: 4px;
    spacing: 6px;
}

QToolBar QToolButton {
    background-color: transparent;
    color: #b8c4d0;
    border: none;
    border-radius: 4px;
    padding: 6px 10px;
}

QToolBar QToolButton:hover {
    background-color: #2e3a46;
    color: #ffffff;
}

QToolBar QToolButton:pressed {
    background-color: #3a6ea5;
    color: #ffffff;
}

/* ---------- ECG TRACE VIEW / GRAPH ---------- */
QGraphicsView, QChartView {
    background-color: #0d1117;
    border: 1px solid #2a313a;
    border-radius: 8px;
    padding: 4px;
}

/* ECG grid lines (if drawn via QFrame or custom widget) */
#ecgGrid {
    background-color: #0d1117;
    border: 1px solid #1e2630;
    border-radius: 8px;
}

/* ECG trace color - bright green for classic monitor look */
#ecgTrace {
    color: #00ff88;
    background-color: transparent;
    border: none;
}

/* ---------- PATIENT INFO PANEL ---------- */
QGroupBox {
    background-color: #1e242c;
    border: 1px solid #2e3640;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 16px;
    color: #c8d0d8;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    background-color: #1e242c;
    color: #90caf9;
}

/* ---------- LABELS ---------- */
QLabel {
    color: #d0d8e0;
    background-color: transparent;
}

QLabel[heading="true"] {
    font-size: 18px;
    font-weight: 600;
    color: #ffffff;
}

QLabel[value="true"] {
    font-size: 22px;
    font-weight: bold;
    color: #00e676;
}

QLabel[warning="true"] {
    color: #ffb74d;
}

QLabel[critical="true"] {
    color: #ff5252;
}

/* ---------- LINES / SEPARATORS ---------- */
QFrame[frameShape="4"] {  /* HLine */
    color: #2e3640;
    background-color: #2e3640;
    max-height: 1px;
}

/* ---------- PUSH BUTTONS ---------- */
QPushButton {
    background-color: #2e3844;
    color: #e0e8f0;
    border: 1px solid #3a4452;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #3e4a5a;
    border-color: #5a6a7a;
}

QPushButton:pressed {
    background-color: #3a6ea5;
    border-color: #4a8ec5;
    color: #ffffff;
}

QPushButton:checked {
    background-color: #2a5a8a;
    border-color: #4a8ec5;
    color: #ffffff;
}

QPushButton:disabled {
    background-color: #262c34;
    color: #6a727a;
    border-color: #2e3640;
}

/* Primary action button (e.g. Start Monitoring, Alarm Reset) */
QPushButton[primary="true"] {
    background-color: #1a6ea5;
    border-color: #2a8ec5;
    color: #ffffff;
    font-weight: 600;
}

QPushButton[primary="true"]:hover {
    background-color: #2a7eb5;
    border-color: #4a9ed5;
}

QPushButton[primary="true"]:pressed {
    background-color: #0a5e95;
}

/* Danger button (e.g. Code Blue, Alarm Silence) */
QPushButton[danger="true"] {
    background-color: #b71c1c;
    border-color: #d32f2f;
    color: #ffffff;
    font-weight: 700;
}

QPushButton[danger="true"]:hover {
    background-color: #c62828;
    border-color: #e53935;
}

/* ---------- LINE EDITS / SPIN BOXES ---------- */
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #141a22;
    color: #e0e8f0;
    border: 1px solid #2e3640;
    border-radius: 6px;
    padding: 6px 10px;
    selection-background-color: #3a6ea5;
}

QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border-color: #4a8ec5;
    background-color: #1a222c;
}

QLineEdit:disabled, QSpinBox:disabled, QDoubleSpinBox:disabled, QComboBox:disabled {
    background-color: #1e242c;
    color: #6a727a;
}

/* ---------- COMBO BOX DROPDOWN ---------- */
QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox::down-arrow {
    image: url(:/icons/down_arrow.png);
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #1e2630;
    border: 1px solid #2e3640;
    border-radius: 6px;
    padding: 4px;
    color: #d0d8e0;
}

QComboBox QAbstractItemView::item {
    padding: 6px 12px;
    border-radius: 4px;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #3a6ea5;
    color: #ffffff;
}

/* ---------- CHECK BOXES ---------- */
QCheckBox {
    color: #c8d0d8;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #3a4452;
    background-color: #141a22;
}

QCheckBox::indicator:checked {
    background-color: #3a6ea5;
    border-color: #4a8ec5;
    image: url(:/icons/check.png);
}

QCheckBox::indicator:hover {
    border-color: #5a7a9a;
}

/* ---------- RADIO BUTTONS ---------- */
QRadioButton {
    color: #c8d0d8;
    spacing: 8px;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border-radius: 9px;
    border: 2px solid #3a4452;
    background-color: #141a22;
}

QRadioButton::indicator:checked {
    background-color: #3a6ea5;
    border-color: #4a8ec5;
}

QRadioButton::indicator:hover {
    border-color: #5a7a9a;
}

/* ---------- SLIDERS ---------- */
QSlider::groove:horizontal {
    height: 6px;
    background-color: #2a323c;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background-color: #4a8ec5;
    width: 16px;
    height: 16px;
    margin: -5px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #5a9ed5;
}

QSlider::sub-page:horizontal {
    background-color: #3a6ea5;
    border-radius: 3px;
}

/* ---------- PROGRESS BARS ---------- */
QProgressBar {
    background-color: #141a22;
    border: 1px solid #2e3640;
    border-radius: 6px;
    text-align: center;
    color: #e0e8f0;
    height: 18px;
}

QProgressBar::chunk {
    background-color: #3a6ea5;
    border-radius: 5px;
}

QProgressBar[warning="true"]::chunk {
    background-color: #ffb74d;
}

QProgressBar[critical="true"]::chunk {
    background-color: #ff5252;
}

/* ---------- TAB WIDGET ---------- */
QTabWidget::pane {
    background-color: #1a2028;
    border: 1px solid #2e3640;
    border-radius: 8px;
    padding: 8px;
}

QTabBar::tab {
    background-color: #252c36;
    color: #b0bcc8;
    border: 1px solid #2e3640;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 8px 18px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #1a6ea5;
    color: #ffffff;
    border-color: #3a7ea5;
}

QTabBar::tab:hover:!selected {
    background-color: #2e3a48;
    color: #e0e8f0;
}

/* ---------- SCROLL BARS ---------- */
QScrollBar:vertical {
    background-color: #1a2028;
    width: 12px;
    border-radius: 6px;
    margin: 2px;
}

QScrollBar::handle:vertical {
    background-color: #3a4452;
    border-radius: 6px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #5a6a7a;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #1a2028;
    height: 12px;
    border-radius: 6px;
    margin: 2px;
}

QScrollBar::handle:horizontal {
    background-color: #3a4452;
    border-radius: 6px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #5a6a7a;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* ---------- STATUS BAR ---------- */
QStatusBar {
    background-color: #141a22;
    color: #b0bcc8;
    border-top: 1px solid #2a323c;
    padding: 4px 8px;
}

QStatusBar QLabel {
    color: #b0bcc8;
}

/* ---------- MESSAGE BOX / DIALOG ---------- */
QMessageBox {
    background-color: #1a2028;
    color: #e0e8f0;
}

QMessageBox QPushButton {
    min-width: 80px;
}

/* ---------- TABLE / TREE VIEWS ---------- */
QTableView, QTreeView, QListWidget {
    background-color: #0d1117;
    color: #d0d8e0;
    border: 1px solid #2a313a;
    border-radius: 6px;
    gridline-color: #1e2630;
    selection-background-color: #2a5a8a;
    selection-color: #ffffff;
}

QHeaderView::section {
    background-color: #1a222c;
    color: #b0bcc8;
    padding: 6px 10px;
    border: none;
    border-right: 1px solid #2a323c;
    border-bottom: 1px solid #2a323c;
    font-weight: 600;
}

QTableView::item:selected, QTreeView::item:selected, QListWidget::item:selected {
    background-color: #2a5a8a;
    color: #ffffff;
}

/* ---------- TOOL TIPS ---------- */
QToolTip {
    background-color: #252c36;
    color: #e8f0f8;
    border: 1px solid #3a4452;
    border-radius: 6px;
    padding: 6px 10px;
}

/* ---------- SPECIAL ECG ALARM INDICATOR ---------- */
#alarmIndicator {
    background-color: #1a1e24;
    border: 2px solid #2e3640;
    border-radius: 12px;
    padding: 8px 16px;
    color: #b0bcc8;
}

#alarmIndicator[active="true"] {
    border-color: #ff5252;
    background-color: #2a0a0a;
    color: #ff5252;
    font-weight: 700;
}

/* ---------- ECG LEAD LABEL (e.g., I, II, III, aVR, etc.) ---------- */
#leadLabel {
    font-size: 14px;
    font-weight: 600;
    color: #90caf9;
    background-color: transparent;
    padding: 2px 8px;
    border: 1px solid #2a3a4a;
    border-radius: 4px;
}

/* ---------- RESPONSIVE FONT FOR HIGH-DPI ---------- */
@media (min-resolution: 144dpi) {
    * {
        font-size: 14px;
    }
    QLabel[heading="true"] {
        font-size: 22px;
    }
    QLabel[value="true"] {
        font-size: 26px;
    }
}

/* ---------- TOUCH / MOBILE FRIENDLY ---------- */
QPushButton, QToolButton {
    min-height: 32px;
}

QComboBox, QLineEdit, QSpinBox, QDoubleSpinBox {
    min-height: 30px;
}

/* ============================================================
   END OF STYLESHEET
   ============================================================ */